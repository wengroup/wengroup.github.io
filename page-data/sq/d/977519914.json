{"data":{"allMarkdownRemark":{"nodes":[{"frontmatter":{"Email":"whuang25@uh.edu","name":"Wei-Fan Huang","date":"2023-01-01T00:00:00.000Z","photo":"people/phd/photo/Wei-Fan_Huang.jpg","description":"Wei-Fan received his B.S. and M.S. in Chemical Engineering from National Cheng Kung University in Taiwan in 2018 and 2021. His research focuses on developing machine learning models and their applications in molecular simulation of battery materials."},"id":"dc8a0a08-d60b-5eff-bca7-1f1752558a8f"},{"frontmatter":{"Email":"eolanrew@uh.edu","name":"Emmanuel A. Olanrewaju","date":"2023-01-02T00:00:00.000Z","photo":"people/phd/photo/Emmanuel_Olanrewaju.jpg","description":"Emmanuel loves computational work to understand and design materials for renewable energy applications. He currently works on data-driven understanding of the stability of zeolites."},"id":"27ba402e-5579-5cee-a0ea-938d3c51397f"},{"frontmatter":{"Email":"qunchen@std.uestc.edu.cn","name":"Qun Chen (陈群)","date":"2025-09-01T00:00:00.000Z","photo":"people/phd/photo/Qun_Chen.jpg","description":"Qun received her M.S. from Shanghai University. Her research focuses on applying density functional theory and developing machine learning methods to study magnetic materials."},"id":"fe61a540-242f-5702-9ff8-4d61e90180b6"},{"frontmatter":{"Email":"202411210402@std.uestc.edu.cn","name":"Cong Wang (王聪)","date":"2025-12-01T00:00:00.000Z","photo":"people/phd/photo/Cong_Wang.jpg","description":"Cong studies magnetic behaviors of functional materials, employing multiscale computational approaches to uncover their fundamental properties and underlying physical mechanisms."},"id":"793944ab-92ca-5ec7-8cce-9433dc99e6a0"}]},"allFile":{"nodes":[{"relativePath":"people/phd/photo/Wei-Fan_Huang.jpg","extension":"jpg","publicURL":"/static/63e862b3b76ede518ef85fa74b1045e3/Wei-Fan_Huang.jpg","childImageSharp":{"gatsbyImageData":{"layout":"constrained","backgroundColor":"#a8a8a8","images":{"fallback":{"src":"/static/63e862b3b76ede518ef85fa74b1